@model ProductListViewModel
@{
    ViewData["Title"] = "Products";
}

<div class="products-page">
    <div class="mb-4">
        <h1 class="display-6 fw-semibold">Products</h1>
        <p class="text-muted mb-0">Browse DeskMart PC components from the database.</p>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label for="search" class="form-label">Search</label>
                    <input type="text"
                           id="search"
                           name="search"
                           class="form-control"
                           value="@Model.Search"
                           placeholder="Product, brand, category, or spec" />
                </div>
                <div class="col-md-3">
                    <label for="category" class="form-label">Category</label>
                    <select id="category" name="category" class="form-select">
                        <option value="">All categories</option>
                        @foreach (var option in Model.CategoryOptions)
                        {
                            if (Model.Category == option.Slug)
                            {
                                <option value="@option.Slug" selected="selected">@option.Name</option>
                            }
                            else
                            {
                                <option value="@option.Slug">@option.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="stockStatus" class="form-label">Stock status</label>
                    <select id="stockStatus" name="stockStatus" class="form-select">
                        <option value="">All</option>
                        @if (Model.StockStatus == "In Stock")
                        {
                            <option value="In Stock" selected="selected">In Stock</option>
                        }
                        else
                        {
                            <option value="In Stock">In Stock</option>
                        }
                        @if (Model.StockStatus == "Low Stock")
                        {
                            <option value="Low Stock" selected="selected">Low Stock</option>
                        }
                        else
                        {
                            <option value="Low Stock">Low Stock</option>
                        }
                        @if (Model.StockStatus == "Out of Stock")
                        {
                            <option value="Out of Stock" selected="selected">Out of Stock</option>
                        }
                        else
                        {
                            <option value="Out of Stock">Out of Stock</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="btn btn-primary">Filter</button>
                </div>
                <div class="col-12">
                    <a asp-action="Index" class="small text-decoration-none">Clear filters</a>
                    <span class="text-muted small ms-2">@Model.TotalCount product(s) found</span>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Products.Count == 0)
    {
        <div class="alert alert-light border" role="alert">
            No products match your filters.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var product in Model.Products)
            {
                var isOutOfStock = product.StockStatus == "Out of Stock";
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm product-card @(isOutOfStock ? "product-card-out-of-stock" : string.Empty)">
                        <div class="product-card-image bg-light d-flex align-items-center justify-content-center">
                            @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                            {
                                <img src="@product.ImageUrl" alt="@product.Name" class="img-fluid product-card-img" />
                            }
                            else
                            {
                                <span class="text-muted small">No image</span>
                            }
                        </div>
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <span class="badge text-bg-light border">@product.CategoryName</span>
                                <span class="badge @ProductDisplayHelper.GetStockBadgeClass(product.StockStatus)">
                                    @product.StockStatus
                                </span>
                            </div>
                            <h2 class="h6 fw-semibold mb-1">@product.Name</h2>
                            <p class="text-muted small mb-2">@product.BrandName</p>
                            @if (!string.IsNullOrWhiteSpace(product.ShortSpecs))
                            {
                                <p class="small text-secondary mb-2">@product.ShortSpecs</p>
                            }
                            <p class="fw-semibold mb-1">@ProductDisplayHelper.FormatVnd(product.Price)</p>
                            <p class="text-muted small mb-3">Stock: @product.StockQuantity</p>
                            <div class="mt-auto d-grid gap-2">
                                <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-primary btn-sm">
                                    View Details
                                </a>
                                <button type="button" class="btn btn-outline-secondary btn-sm" disabled title="Coming soon">
                                    Add to Build
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" disabled title="Coming soon">
                                    Add to Cart
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

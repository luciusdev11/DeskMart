@{
    ViewData["Title"] = "PC Builder";
    var slots = new[] { "CPU", "Motherboard", "RAM", "GPU", "SSD", "PSU", "Case", "Cooler" };
}

<div class="pc-builder-page">
    <div class="mb-4">
        <h1 class="display-6 fw-semibold">DeskMart PC Builder</h1>
        <p class="text-muted mb-1">
            Select components, check stock and compatibility notes, then ask AI to analyze the build.
        </p>
        <p class="text-muted small mb-0">
            Products are loaded from the DeskMart SQL Server catalog.
        </p>
    </div>

    <div id="pcBuilderProductsLoading" class="alert alert-light border mb-4">
        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
        Loading PC Builder products...
    </div>

    <div id="pcBuilderProductsError" class="alert alert-danger d-none mb-4" role="alert"></div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="row g-3" id="pcBuilderSlots">
                @foreach (var slot in slots)
                {
                    <div class="col-md-6">
                        <div class="card h-100 border-0 shadow-sm pc-builder-slot-card" data-slot="@slot">
                            <div class="card-body">
                                <h2 class="h6 fw-semibold mb-3">@slot</h2>
                                <label class="form-label visually-hidden" for="pcBuilderSelect-@slot">Select @slot</label>
                                <select id="pcBuilderSelect-@slot"
                                        class="form-select pc-builder-slot-select"
                                        data-slot="@slot">
                                    <option value="">-- Select @slot --</option>
                                </select>
                                <div class="pc-builder-slot-info mt-3 text-muted small" data-slot-info="@slot">
                                    No component selected.
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm pc-builder-summary-card">
                <div class="card-body">
                    <h2 class="h5 fw-semibold mb-3">Build summary</h2>

                    <dl class="row mb-3 small">
                        <dt class="col-7">Total price</dt>
                        <dd class="col-5 text-end fw-semibold mb-2" id="pcBuilderTotalPrice">0 VND</dd>

                        <dt class="col-7">Estimated power</dt>
                        <dd class="col-5 text-end mb-2" id="pcBuilderEstimatedPower">0 W</dd>

                        <dt class="col-7">Recommended PSU</dt>
                        <dd class="col-5 text-end mb-0" id="pcBuilderRecommendedPsu">0 W</dd>
                    </dl>

                    <div class="mb-3">
                        <h3 class="h6 fw-semibold">Compatibility warnings</h3>
                        <ul class="list-unstyled small mb-0" id="pcBuilderCompatibilityWarnings">
                            <li class="text-muted">None</li>
                        </ul>
                    </div>

                    <div class="mb-4">
                        <h3 class="h6 fw-semibold">Stock warnings</h3>
                        <ul class="list-unstyled small mb-0" id="pcBuilderStockWarnings">
                            <li class="text-muted">None</li>
                        </ul>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="button" id="pcBuilderAnalyzeBtn" class="btn btn-primary" disabled>
                            Analyze with AI
                        </button>
                    </div>

                    <div id="pcBuilderLoading" class="text-muted small mt-3 d-none">
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        Analyzing...
                    </div>

                    <div id="pcBuilderAnalysisResult" class="mt-4 d-none">
                        <h3 class="h6 fw-semibold mb-2">AI analysis</h3>
                        <div id="pcBuilderAnalysisCard" class="card border-0">
                            <div class="card-body p-3 pc-builder-analysis-content"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/pc-builder.js" asp-append-version="true"></script>
}

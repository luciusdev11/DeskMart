# DeskMart local environment (example)
#
# 1. Copy this file to .env in the SAME folder (DeskMart/):
#      copy env.example .env
# 2. Fill in NestyAI__BaseUrl and NestyAI__ApiKey
# 3. dotnet run --project DeskMart\DeskMart.csproj
#
# ASP.NET Core maps double underscore to nested config (NestyAI:ApiKey).

ASPNETCORE_ENVIRONMENT=Development

# SQL Server (optional — overrides appsettings.json when set)
ConnectionStrings__DefaultConnection=Server=localhost;Database=DeskMartDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true

# NestyAI — required for /AiAdvisor and /PcBuilder Analyze with AI
NestyAI__BaseUrl=
NestyAI__ApiKey=
NestyAI__ChatCompletionsEndpoint=/v1/chat/completions
NestyAI__DefaultModel=nesty-combined-1.0
NestyAI__TimeoutSeconds=60
